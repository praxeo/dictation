<Window x:Class="WhisperInk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperInk RT"
        Height="38" Width="180"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        MouseRightButtonUp="Window_MouseRightButtonUp"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border x:Name="MainBorder" CornerRadius="8" Background="#CC1A1A1A"
            BorderBrush="#404040" BorderThickness="2">
        <Grid Margin="6,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label x:Name="lblStatus" Grid.Column="0"
                   Content="Ready (RT)" Foreground="#CCCCCC"
                   FontSize="11" Padding="0"
                   VerticalAlignment="Center"/>

            <StackPanel x:Name="HistogramPanel" Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" Margin="4,0,0,0">
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
                <Border Width="3" Height="2" Background="#66FF66" Margin="1,0" CornerRadius="1"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
